# Shotwright environment configuration
# Copy to .env and customize

# --- Security ---
SHOTWRIGHT_SECRET_KEY=change-me-in-production
SHOTWRIGHT_ADMIN_PASSWORD=admin

# --- GitHub / Copilot ---
SHOTWRIGHT_GITHUB_TOKEN=
SHOTWRIGHT_COPILOT_MODEL=gpt-5.4
# SHOTWRIGHT_SKILLS_VERIFY_SSL=true
# SHOTWRIGHT_SKILLS_DOWNLOAD_BUFFER_SIZE=65536
# SHOTWRIGHT_SKILLS_DOWNLOAD_BACKEND=curl

# --- Proxy (optional) ---
# http_proxy=http://proxy.example.com:8080
# https_proxy=http://proxy.example.com:8080

# --- Package mirrors (optional) ---
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
# PIP_TRUSTED_HOST=mirrors.aliyun.com
# NPM_REGISTRY=https://registry.npmmirror.com

# --- MongoDB ---
# SHOTWRIGHT_MONGO_URI=mongodb://mongo:27017
# SHOTWRIGHT_MONGO_DB=shotwright

# --- Docker ---
# SHOTWRIGHT_DOCKER_HOST=npipe:////./pipe/docker_engine
# SHOTWRIGHT_SHOTWRIGHT_IMAGE=shotwright:runtime
# SHOTWRIGHT_CONTAINER_PAYLOAD_MOUNT_AUTO_DETECT=false
# SHOTWRIGHT_CONTAINER_PAYLOAD_MOUNT_SOURCE=
